{
	"name": "bg3-osiris",
	"displayName": "BG3 Osiris",
	"description": "",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.103.0"
	},
	"publisher": "SASUKE38",
	"repository": {
		"type": "git",
		"url": "https://github.com/SASUKE38/bg3-osiris"
	},
	"categories": [
		"Programming Languages",
		"Snippets"
	],
	"activationEvents": [],
	"main": "./client/out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "bg3Osiris.OpenGoal",
				"title": "Open"
			}
		],
		"languages": [
			{
				"id": "osiris",
				"aliases": [
					"Osiris",
					"osiris"
				],
				"extensions": [
					".txt"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "osiris",
				"scopeName": "source.osiris",
				"path": "./syntaxes/osiris.tmLanguage.json"
			}
		],
		"snippets": [
			{
				"language": "osiris",
				"path": "./syntaxes/osiris.tmSnippet.json"
			}
		],
		"themes": [
			{
				"id": "osiris.theme",
				"label": "Osiris",
				"path": "./syntaxes/osiris.tmTheme.json",
				"uiTheme": "vs-dark"
			}
		],
		"semanticTokenTypes": [
			{
				"id": "osiris_builtin",
				"superType": "function",
				"description": "A built in Osiris procedure, query, or event."
			},
			{
				"id": "call",
				"superType": "osiris_builtin",
				"description": "An osiris PROC."
			},
			{
				"id": "query",
				"superType": "osiris_builtin",
				"description": "An osiris QRY."
			},
			{
				"id": "event",
				"superType": "osiris_builtin",
				"description": "An osiris event."
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "story-outline",
					"title": "Story Outline",
					"icon": "./media/dep.svg"
				}
			]
		},
		"views": {
			"story-outline": [
				{
					"id": "story-outline",
					"name": "Story Outline",
					"icon": "./media/dep.svg"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "story-outline",
				"contents": "No story items found."
			}
		],
		"configuration": {
			"type": "object",
			"title": "BG3 Osiris",
			"properties": {
				"bg3Osiris.dependencyPaths": {
					"scope": "machine",
					"type": "array",
					"items": {
						"type": "string",
						"title": "Path"
					},
					"description": "Directories to search in when looking for dependencies."
				},
				"bg3Osiris.baseMods": {
					"scope": "window",
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"pakName": {
								"type": "string"
							},
							"contents": {
								"type": "array",
								"items": {
									"type": "string"
								}
							}
						},
						"additionalProperties": false
					},
					"default": [
						{
							"pakName": "Shared.pak",
							"contents": [
								"Shared",
								"SharedDev"
							]
						},
						{
							"pakName": "Gustav.pak",
							"contents": [
								"Gustav",
								"GustavDev"
							]
						}
					]
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.38.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^16.4.0",
		"jiti": "^2.6.1",
		"mocha": "^10.3.0",
		"prettier": "3.6.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.1"
	},
	"dependencies": {
		"electron-edge-js": "^42.0.0",
		"fast-xml-parser": "^5.3.2"
	}
}
